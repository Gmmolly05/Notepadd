{
  "name": "notepadd",
  "productName": "Notepadd",
  "version": "1.1.1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gmmolly05/Notepadd.git"
  },
  "type": "module",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.notepadd.app",
    "productName": "Notepadd",
    "artifactName": "${productName}-Setup-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Gmmolly05",
        "repo": "Notepadd"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}